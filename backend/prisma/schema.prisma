generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  date      String   // Now storing 'YYYY-MM-DD' as string
  intakeMl  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, date])
}

