// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WaterLog {
  id        Int      @id @default(autoincrement())
  userId    String
  date      String
  intakeMl  Int

  @@unique([userId, date], name: "userId_date")
}
