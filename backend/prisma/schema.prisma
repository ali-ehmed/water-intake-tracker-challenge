generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  intakeMl  Int
  createdAt DateTime @default(now())

  @@unique([userId, date])
}